{
  "manifest_version": 3,
  "name": "Vinted Sales Helper",
  "version": "1.0.0",
  "description": "Automation tools for Vinted Seller.",
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://vinted-sales-helper-api.onrender.com/*",
    "https://*.vinted.fr/*",
    "https://*.vinted.de/*",
    "https://*.vinted.es/*",
    "https://*.vinted.it/*",
    "https://*.vinted.pt/*",
    "https://*.vinted.nl/*",
    "https://*.vinted.be/*",
    "https://*.vinted.pl/*",
    "https://*.vinted.cz/*",
    "https://*.vinted.lt/*",
    "https://*.vinted.lu/*",
    "https://*.vinted.at/*",
    "https://*.vinted.hu/*",
    "https://*.vinted.sk/*",
    "https://*.vinted.ro/*",
    "https://*.vinted.bg/*",
    "https://*.vinted.hr/*",
    "https://*.vinted.co.uk/*",
    "https://*.vinted.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vinted.fr/*",
        "https://*.vinted.de/*",
        "https://*.vinted.es/*",
        "https://*.vinted.it/*",
        "https://*.vinted.pt/*",
        "https://*.vinted.nl/*",
        "https://*.vinted.be/*",
        "https://*.vinted.pl/*",
        "https://*.vinted.cz/*",
        "https://*.vinted.lt/*",
        "https://*.vinted.lu/*",
        "https://*.vinted.at/*",
        "https://*.vinted.hu/*",
        "https://*.vinted.sk/*",
        "https://*.vinted.ro/*",
        "https://*.vinted.bg/*",
        "https://*.vinted.hr/*",
        "https://*.vinted.co.uk/*",
        "https://*.vinted.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
